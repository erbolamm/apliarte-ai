{
  "name": "apliarte-ai",
  "displayName": "ApliArte AI — Chat de IA Local",
  "description": "Chat de IA local para VS Code. Corre modelos directo en tu máquina o conecta LM Studio/Ollama. Sin APIs externas, 100% privado, 0 coste.",
  "version": "0.5.3",
  "icon": "icon.png",
  "publisher": "apliarte",
  "author": {
    "name": "Javier Mateo (ApliArte)",
    "url": "https://github.com/erbolamm"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erbolamm/apliarte-ai"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Chat",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "apliarte-ai",
    "lmstudio",
    "ollama",
    "local-ai",
    "continue",
    "gemma",
    "ia-gratis",
    "español"
  ],
  "activationEvents": [
    "onView:apliarteAi.chatView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apliarteAi",
          "title": "ApliArte AI",
          "icon": "media/icon-dark.svg"
        }
      ]
    },
    "views": {
      "apliarteAi": [
        {
          "type": "webview",
          "id": "apliarteAi.chatView",
          "name": "Chat"
        },
        {
          "id": "apliarteAi.workspaceView",
          "name": "Workspace",
          "icon": "$(folder)"
        }
      ]
    },
    "commands": [
      {
        "command": "apliarteAi.setup",
        "title": "ApliArte AI: Configurar IA Local",
        "icon": "$(rocket)"
      },
      {
        "command": "apliarteAi.detectProviders",
        "title": "ApliArte AI: Detectar LM Studio / Ollama"
      },
      {
        "command": "apliarteAi.changePreset",
        "title": "ApliArte AI: Cambiar Preset"
      },
      {
        "command": "apliarteAi.sendFileToChat",
        "title": "ApliArte AI: Enviar archivo al chat",
        "icon": "$(file)"
      },
      {
        "command": "apliarteAi.sendSelectionToChat",
        "title": "ApliArte AI: Enviar selección al chat",
        "icon": "$(selection)"
      },
      {
        "command": "apliarteAi.sendSelectedFiles",
        "title": "ApliArte AI: Enviar archivos seleccionados al chat",
        "icon": "$(files)"
      },
      {
        "command": "apliarteAi.refreshWorkspace",
        "title": "Refrescar",
        "icon": "$(refresh)"
      },
      {
        "command": "apliarteAi.toggleFile",
        "title": "Seleccionar/Deseleccionar archivo"
      },
      {
        "command": "apliarteAi.action.explain",
        "title": "ApliArte AI: Explicar código"
      },
      {
        "command": "apliarteAi.action.refactor",
        "title": "ApliArte AI: Refactorizar"
      },
      {
        "command": "apliarteAi.action.bugs",
        "title": "ApliArte AI: Buscar bugs"
      },
      {
        "command": "apliarteAi.action.tests",
        "title": "ApliArte AI: Generar tests"
      },
      {
        "command": "apliarteAi.action.docs",
        "title": "ApliArte AI: Documentar"
      },
      {
        "command": "apliarteAi.action.optimize",
        "title": "ApliArte AI: Optimizar"
      },
      {
        "command": "apliarteAi.recommendModels",
        "title": "ApliArte AI: Recomendar modelos para mi equipo"
      },
      {
        "command": "apliarteAi.indexWorkspace",
        "title": "ApliArte AI: Indexar workspace (RAG)",
        "icon": "$(cloud-upload)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "apliarteAi.submenu",
          "group": "apliarteAi@1"
        }
      ],
      "apliarteAi.submenu": [
        {
          "command": "apliarteAi.sendSelectionToChat",
          "when": "editorHasSelection",
          "group": "send@1"
        },
        {
          "command": "apliarteAi.sendFileToChat",
          "group": "send@2"
        },
        {
          "command": "apliarteAi.action.explain",
          "when": "editorHasSelection",
          "group": "actions@1"
        },
        {
          "command": "apliarteAi.action.refactor",
          "when": "editorHasSelection",
          "group": "actions@2"
        },
        {
          "command": "apliarteAi.action.bugs",
          "when": "editorHasSelection",
          "group": "actions@3"
        },
        {
          "command": "apliarteAi.action.tests",
          "when": "editorHasSelection",
          "group": "actions@4"
        },
        {
          "command": "apliarteAi.action.docs",
          "when": "editorHasSelection",
          "group": "actions@5"
        },
        {
          "command": "apliarteAi.action.optimize",
          "when": "editorHasSelection",
          "group": "actions@6"
        }
      ],
      "view/title": [
        {
          "command": "apliarteAi.refreshWorkspace",
          "when": "view == apliarteAi.workspaceView",
          "group": "navigation"
        },
        {
          "command": "apliarteAi.sendSelectedFiles",
          "when": "view == apliarteAi.workspaceView",
          "group": "navigation"
        }
      ]
    },
    "submenus": [
      {
        "id": "apliarteAi.submenu",
        "label": "ApliArte AI"
      }
    ],
    "keybindings": [
      {
        "command": "apliarteAi.sendSelectionToChat",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "apliarteAi.action.explain",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "ApliArte AI",
      "properties": {
        "apliarteAi.preset": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "ecosystem-only",
            "full-gentleman"
          ],
          "enumDescriptions": [
            "Lite — Solo personalidad + SDD básico (~5k tokens). Ideal para modelos ≤ 8B",
            "Medium — SDD + skills de foundation (~20k tokens). Para modelos 13B-30B",
            "Full — Todo el ecosistema Gentleman (~49k tokens). Para modelos grandes o APIs"
          ],
          "description": "Preset de configuración según la capacidad del modelo local"
        },
        "apliarteAi.lmstudioEndpoint": {
          "type": "string",
          "default": "http://localhost:1234/v1",
          "description": "URL del servidor LM Studio"
        },
        "apliarteAi.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "URL del servidor Ollama"
        },
        "apliarteAi.language": {
          "type": "string",
          "default": "es",
          "enum": [
            "es",
            "en"
          ],
          "enumDescriptions": [
            "Español",
            "English"
          ],
          "description": "Idioma del agente"
        },
        "apliarteAi.agentEndpoint": {
          "type": "string",
          "default": "",
          "description": "URL del servidor ApliArte Code Agent (ej: https://agent.apliarte.com). Dejar vacío para desactivar."
        },
        "apliarteAi.agentApiKey": {
          "type": "string",
          "default": "",
          "description": "API key para conectar con el agente remoto"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/codicons": "^0.0.45",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0"
  }
}
